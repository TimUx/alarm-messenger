# Server Configuration
PORT=3000
NODE_ENV=development

# Database
DATABASE_PATH=./data/alarm-messenger.db

# Security
# IMPORTANT: These secrets can be provided in Base64-encoded format for additional obfuscation
# Plain text is still supported for backward compatibility
# To generate a Base64-encoded secret: echo -n "your-secret-here" | base64
# Or use Node.js: node -e "console.log(Buffer.from('your-secret-here').toString('base64'))"
# Example Base64 values below (decode to: your-secret-key-here / your-jwt-secret-here)
API_SECRET_KEY=eW91ci1zZWNyZXQta2V5LWhlcmU=
JWT_SECRET=eW91ci1qd3Qtc2VjcmV0LWhlcmU=

# Server URL (for QR code generation)
SERVER_URL=http://localhost:3000

# Optional SMTP for registration invite emails (POST /api/devices/registration-token/email)
# If unset, the API still returns registrationLink; email.sent will be false.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# CORS Configuration (comma-separated list of allowed origins)
# IMPORTANT: Do NOT use * in production – always specify explicit origins.
# Example: CORS_ORIGINS=https://alarm.example.com,https://admin.example.com
CORS_ORIGINS=*
